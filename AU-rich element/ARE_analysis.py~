def load_data(are_file, rbp_file):
    """Load and validate input files."""
    print("Loading input files...")

    # Validate files exist
    for f in [are_file, rbp_file]:
        if not os.path.exists(f):
            sys.exit(f"ERROR: Input file not found: {f}")

    are = pd.read_csv(are_file)
    rbp = pd.read_csv(rbp_file)

    # Validate required columns
    required_are = ['Gene', 'Intervention_logFC', 'Intervention_P.Value',
                    'group', 'utr_length', 'AREScore', 'ARED_cluster', 'n_7mer_L2']
    required_rbp = ['RBP', 'Role', 'DOWN_OR', 'DOWN_CI_low', 'DOWN_CI_high',
                    'DOWN_p', 'partial_rho', 'partial_p']

    missing_are = [c for c in required_are if c not in are.columns]
    missing_rbp = [c for c in required_rbp if c not in rbp.columns]

    if missing_are:
        sys.exit(f"ERROR: Missing columns in ARE file: {missing_are}")
    if missing_rbp:
        sys.exit(f"ERROR: Missing columns in RBP file: {missing_rbp}")

    # Validate group assignments
    expected_groups = {'down', 'background', 'up'}
    actual_groups   = set(are['group'].unique())
    if not expected_groups == actual_groups:
        sys.exit(f"ERROR: Unexpected groups in ARE file: {actual_groups}")

    n_down = (are['group'] == 'down').sum()
    n_bg   = (are['group'] == 'background').sum()
    n_up   = (are['group'] == 'up').sum()

    print(f"  ARE file: {len(are)} genes — down={n_down}, background={n_bg}, up={n_up}")

    # Sanity checks
    assert n_down == 109,  f"Expected 109 downregulated genes, got {n_down}"
    assert n_bg   == 9588, f"Expected 9,588 background genes, got {n_bg}"
    assert n_up   == 35,   f"Expected 35 upregulated genes, got {n_up}"

    assert are['AREScore'].isna().sum() == 0, "NaN values in AREScore"
    assert are['n_7mer_L2'].isna().sum() == 0, "NaN values in n_7mer_L2"
    assert are['utr_length'].isna().sum() == 0, "NaN values in utr_length"
    assert (are['utr_length'] > 0).all(), "Non-positive UTR lengths detected"

    print(f"  RBP file: {len(rbp)} RBPs")
    print("  Input validation: PASSED")
    return are, rbp


