def save_statistics(stats, rbp_recomputed, rbp, out_dir):
    """Save all verified statistics to CSV for reproducibility."""

    rows = []
    for k, v in stats.items():
        rows.append({'statistic': k, 'value': v, 'source': '02_ARE_annotations.csv'})
    for k, v in rbp_recomputed.items():
        rows.append({'statistic': k, 'value': v, 'source': '02_ARE_annotations.csv'})

    df = pd.DataFrame(rows)
    out = os.path.join(out_dir, "ARE_statistics_verified.csv")
    df.to_csv(out, index=False)
    print(f"\nVerified statistics saved: {out}")

    # Also save RBP table with recomputed ZFP36L2 check
    rbp_out = rbp.copy()
    rbp_out['ZFP36L2_OR_independently_verified'] = (
        rbp_out['RBP'].apply(
            lambda x: rbp_recomputed.get('ZFP36L2_OR_recomputed', '') if x=='ZFP36L2' else ''
        )
    )
    rbp_out.to_csv(os.path.join(out_dir, "RBP_statistics_verified.csv"), index=False)


