def fig_are_bar(are, stats, out_dir):
    """
    Figure 6C: ARE bar chart.
    Shows % of genes with AREScore >= 4 in each expression group.
    """
    print("\nGenerating Figure 6C (ARE bar chart)...")

    groups  = ["Downregulated\n(n = 109)", "Background\n(n = 9,588)",
               "Upregulated\n(n = 35)\nneg. control"]
    pcts    = [stats['d_pct'], stats['b_pct'], stats['u_pct']]
    ci_lo   = [stats['d_pct'] - stats['d_ci_lo'],
               stats['b_pct'] - stats['b_ci_lo'],
               stats['u_pct'] - stats['u_ci_lo']]
    ci_hi   = [stats['d_ci_hi'] - stats['d_pct'],
               stats['b_ci_hi'] - stats['b_pct'],
               stats['u_ci_hi'] - stats['u_pct']]
    colors  = [COL_DOWN, COL_BG, COL_UP]
    counts  = [f"{stats['d_pos']}/109",
               f"{stats['b_pos']}/9588",
               f"{stats['u_pos']}/35"]
    ns      = [109, 9588, 35]

    fig, ax = plt.subplots(figsize=(7, 5.5), facecolor='white')
    ax.set_facecolor('white')

    x = np.arange(3)
    bars = ax.bar(x, pcts, width=0.5, color=colors, alpha=0.85, zorder=3)
    ax.errorbar(x, pcts, yerr=[ci_lo, ci_hi],
                fmt='none', color='#333333', capsize=5,
                linewidth=1.4, zorder=4)

    # Count labels inside bars
    for i, (bar, cnt) in enumerate(zip(bars, counts)):
        ax.text(bar.get_x() + bar.get_width()/2, pcts[i]/2,
                cnt, ha='center', va='center',
                fontsize=9.5, color='white', fontweight='bold')

    # Statistical annotations — no connecting lines
    ax.text(0, stats['d_pct'] + ci_hi[0] + 3,
            f"OR = {stats['or_down_bg']:.2f} ({stats['ci_lo_down_bg']:.2f}–{stats['ci_hi_down_bg']:.2f})\n"
            f"p = {stats['p_down_bg']:.2e}",
            ha='center', va='bottom', fontsize=9,
            color=COL_DOWN, fontweight='bold')

    ax.text(2, stats['u_pct'] + ci_hi[2] + 2,
            f"OR = {stats['or_up_bg']:.2f}\np = {stats['p_up_bg']:.3f}",
            ha='center', va='bottom', fontsize=9, color=COL_UP)

    ax.set_xticks(x)
    ax.set_xticklabels(groups, fontsize=10.5)
    ax.set_ylabel("Genes with AREScore \u2265 4 (%)", fontsize=11)
    ax.set_ylim(0, 88)
    ax.set_xlim(-0.5, 2.5)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    ax.tick_params(axis='y', labelsize=9.5)
    ax.text(0.01, -0.13,
        "AREScore \u2265 4: ARED-Plus (Bakheet et al. 2018). "
        "Fisher\u2019s exact: downregulated vs background. Error bars: 95% CI (Wilson).",
        transform=ax.transAxes, fontsize=8, color='#555555', va='top')

    plt.tight_layout(rect=[0, 0.05, 1, 1])
    out = os.path.join(out_dir, "Fig_6C_ARE_bar.pdf")
    plt.savefig(out, format='pdf', bbox_inches='tight', facecolor='white')
    plt.close()
    print(f"  Saved: {out}")


def fig_rbp_forest(rbp, out_dir):
    """
    Figure 6D: RBP motif specificity forest plot.
    Uses precomputed statistics from 03_RBP_specificity.csv.
    Note: ZFP36L2 statistics independently verified (see recompute_rbp_stats).
    """
    print("\nGenerating Figure 6D (RBP forest plot)...")

    rbp_plot = rbp.copy()
    rbp_plot = rbp_plot.iloc[::-1].reset_index(drop=True)  # reverse for forest plot order

    fig, ax = plt.subplots(figsize=(8, 5), facecolor='white')
    ax.set_facecolor('white')

    y = np.arange(len(rbp_plot))

    for i, row in rbp_plot.iterrows():
        color  = COL_DEST if row['Role'] == 'destabiliser' else COL_STAB
        filled = row['DOWN_p'] < 0.05

        # Error bar
        ax.plot([row['DOWN_CI_low'], row['DOWN_CI_high']], [i, i],
                color=color, linewidth=1.8, zorder=2, solid_capstyle='round')
        # Point
        ax.scatter(row['DOWN_OR'], i, s=90, zorder=3,
                   color=color if filled else 'white',
                   edgecolors=color, linewidths=2.0)

    ax.axvline(1.0, color='#555555', linewidth=1.0,
               linestyle='--', zorder=1)

    # RBP labels
    rbp_labels = [f"{r['RBP']}" for _, r in rbp_plot.iterrows()]
    ax.set_yticks(y)
    ax.set_yticklabels(rbp_labels, fontsize=10.5)
    ax.set_xlabel("Odds ratio (downregulated vs background; Fisher\u2019s exact)",
                  fontsize=10)
    ax.set_xlim(0.3, 4.0)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)

    # Legend
    legend_handles = [
        Line2D([0],[0], marker='o', color='w', markerfacecolor=COL_DEST,
               markeredgecolor=COL_DEST, markersize=9, label='Destabiliser'),
        Line2D([0],[0], marker='o', color='w', markerfacecolor='white',
               markeredgecolor=COL_DEST, markersize=9, markeredgewidth=2,
               label='Destabiliser (ns)'),
        Line2D([0],[0], marker='o', color='w', markerfacecolor='white',
               markeredgecolor=COL_STAB, markersize=9, markeredgewidth=2,
               label='Stabiliser (HuR)'),
        Line2D([0],[0], color='none', label='Filled: p < 0.05'),
    ]
    ax.legend(handles=legend_handles, fontsize=8.5, loc='lower right',
              frameon=True, framealpha=0.9, edgecolor='#DDDDDD')

    ax.text(0.01, -0.12,
        "Orange: AU-rich destabilisers; black: stabiliser (HuR). "
        "All motifs tested on identical 3\u2032 UTR sequences (UTR-length-neutral).",
        transform=ax.transAxes, fontsize=8, color='#555555', va='top')

    plt.tight_layout(rect=[0, 0.08, 1, 1])
    out = os.path.join(out_dir, "Fig_6D_RBP_forest.pdf")
    plt.savefig(out, format='pdf', bbox_inches='tight', facecolor='white')
    plt.close()
    print(f"  Saved: {out}")


def fig_cdf(are, stats, out_dir):
    """
    Figure S1: Cumulative distribution of ITT log2FC by 7-mer count.
    """
    print("\nGenerating Figure S1 (CDF)...")

    ge2  = are[are['n_7mer_L2'] >= 2]['Intervention_logFC'].sort_values()
    one  = are[are['n_7mer_L2'] == 1]['Intervention_logFC'].sort_values()
    zero = are[are['n_7mer_L2'] == 0]['Intervention_logFC'].sort_values()

    fig, ax = plt.subplots(figsize=(7, 5), facecolor='white')
    ax.set_facecolor('white')

    for data, label, color, lw in [
        (zero, "0 7-mers",    COL_BG,   1.2),
        (one,  "1 7-mer",     "#E8967A", 1.8),
        (ge2,  "\u2265 2 7-mers", COL_DOWN, 2.2),
    ]:
        y = np.arange(1, len(data)+1) / len(data)
        ax.plot(data, y, color=color, linewidth=lw, label=f"{label} (n={len(data):,})")

    ax.axvline(0, color='#AAAAAA', linewidth=0.7, linestyle='--')
    ax.set_xlabel("ITT log\u2082FC (SKY vs control)", fontsize=10.5)
    ax.set_ylabel("Cumulative proportion", fontsize=10.5)
    ax.legend(fontsize=9, frameon=True, framealpha=0.9, edgecolor='#DDDDDD',
              loc='upper left')
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)

    ax.text(0.01, -0.12,
        f"Fisher\u2019s exact (\u22652 vs <2 7-mers): "
        f"OR={stats['cdf_or_ge2_vs_lt2']:.2f}, "
        f"p={stats['cdf_p_ge2_vs_lt2']:.2e}. "
        "UAUUUAU: ZFP36 family 7-mer (Redmon et al. 2022).",
        transform=ax.transAxes, fontsize=8, color='#555555', va='top')

    plt.tight_layout(rect=[0, 0.08, 1, 1])
    out = os.path.join(out_dir, "Fig_S1_CDF_7mer.pdf")
