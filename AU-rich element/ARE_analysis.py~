# 2. STATISTICAL TESTS
# ══════════════════════════════════════════════════════════════════════════

def wilson_ci(k, n, z=1.96):
    """Wilson 95% confidence interval for proportion."""
    p = k / n
    denom  = 1 + z**2 / n
    centre = (p + z**2 / (2*n)) / denom
    margin = z * np.sqrt(p*(1-p)/n + z**2/(4*n**2)) / denom
    return (centre - margin) * 100, (centre + margin) * 100


def or_confidence_interval(a, b, c, d, z=1.96):
    """Woolf logit 95% CI for odds ratio."""
    log_or = np.log(a * d / (b * c))
    se     = np.sqrt(1/a + 1/b + 1/c + 1/d)
    return np.exp(log_or - z*se), np.exp(log_or + z*se)


def partial_spearman(x, y, covariate):
    """
    Partial Spearman correlation between x and y controlling for covariate.
    Method: residualise both x and y on covariate using Spearman rank
    correlation of residuals (Mukherjee et al. Genome Biol 2014).
    """
    # Residualise x on covariate
    _, _, _, _, res_x = np.polyfit(covariate, x, 1, full=False), None, None, None, None
    # Use scipy for rank-based residuals
    from scipy.stats import rankdata
    def spearman_residuals(a, b):
        ra, rb = rankdata(a), rankdata(b)
        slope  = np.cov(rb, ra)[0,1] / np.var(ra)
        intercept = np.mean(rb) - slope * np.mean(ra)
        return rb - (slope * ra + intercept)

    res_x = spearman_residuals(covariate, x)
    res_y = spearman_residuals(covariate, y)
    rho, p = spearmanr(res_x, res_y)
    return rho, p


def run_are_statistics(are):
    """
    Compute all ARE enrichment statistics reported in the manuscript.
    Returns dict of all verified statistics.
    """
    print("\nComputing ARE enrichment statistics...")

    down = are[are['group'] == 'down']
    bg   = are[are['group'] == 'background']
    up   = are[are['group'] == 'up']

    threshold = 4  # AREScore >= 4

    # ── ARE-positive counts ─────────────────────────────────────────────
    d_pos = (down['AREScore'] >= threshold).sum()
    b_pos = (bg['AREScore']   >= threshold).sum()
    u_pos = (up['AREScore']   >= threshold).sum()
    d_neg = len(down) - d_pos
    b_neg = len(bg)   - b_pos
    u_neg = len(up)   - u_pos

    d_pct = d_pos / len(down) * 100
    b_pct = b_pos / len(bg)   * 100
    u_pct = u_pos / len(up)   * 100

    # ── Fisher exact tests ──────────────────────────────────────────────
    or_db, p_db = fisher_exact([[d_pos, d_neg], [b_pos, b_neg]])
    or_ub, p_ub = fisher_exact([[u_pos, u_neg], [b_pos, b_neg]])
    ci_db_lo, ci_db_hi = or_confidence_interval(d_pos, d_neg, b_pos, b_neg)

    # ── Wilson CIs for bar chart ────────────────────────────────────────
    d_ci_lo, d_ci_hi = wilson_ci(d_pos, len(down))
    b_ci_lo, b_ci_hi = wilson_ci(b_pos, len(bg))
    u_ci_lo, u_ci_hi = wilson_ci(u_pos, len(up))

    # ── UTR length test ─────────────────────────────────────────────────
    _, mw_p = mannwhitneyu(down['utr_length'], bg['utr_length'],
                           alternative='two-sided')
    d_utr_med = down['utr_length'].median()
    b_utr_med = bg['utr_length'].median()

    # ── Partial Spearman — primary pre-specified test ───────────────────
    # 7-mer count vs log2FC, controlling for log10(UTR length)
    log_utr  = np.log10(are['utr_length'])
    rho_7mer, p_7mer = partial_spearman(
        are['n_7mer_L2'].values,
        are['Intervention_logFC'].values,
        log_utr.values
    )

    # AREScore vs log2FC, controlling for log10(UTR length)
    rho_are, p_are = partial_spearman(
        are['AREScore'].values,
        are['Intervention_logFC'].values,
        log_utr.values
    )

    # ── CDF Fisher: >= 2 7-mers vs < 2 7-mers ──────────────────────────
    ge2 = are[are['n_7mer_L2'] >= 2]
    lt2 = are[are['n_7mer_L2'] <  2]
    ge2_dn = (ge2['group'] == 'down').sum()
    ge2_nd = (ge2['group'] != 'down').sum()
    lt2_dn = (lt2['group'] == 'down').sum()
    lt2_nd = (lt2['group'] != 'down').sum()
    or_7mer_cdf, p_7mer_cdf = fisher_exact([[ge2_dn, ge2_nd], [lt2_dn, lt2_nd]])

    # ── Collect results ─────────────────────────────────────────────────
    stats = {
        'n_down':           len(down),
        'n_background':     len(bg),
        'n_up':             len(up),
        'are_threshold':    threshold,
        'd_pos':            int(d_pos),
        'b_pos':            int(b_pos),
        'u_pos':            int(u_pos),
        'd_pct':            round(d_pct, 2),
        'b_pct':            round(b_pct, 2),
        'u_pct':            round(u_pct, 2),
        'd_ci_lo':          round(d_ci_lo, 2),
        'd_ci_hi':          round(d_ci_hi, 2),
        'b_ci_lo':          round(b_ci_lo, 2),
        'b_ci_hi':          round(b_ci_hi, 2),
        'u_ci_lo':          round(u_ci_lo, 2),
        'u_ci_hi':          round(u_ci_hi, 2),
        'or_down_bg':       round(or_db, 4),
        'ci_lo_down_bg':    round(ci_db_lo, 4),
        'ci_hi_down_bg':    round(ci_db_hi, 4),
        'p_down_bg':        float(p_db),
        'or_up_bg':         round(or_ub, 4),
        'p_up_bg':          float(p_ub),
        'd_utr_median_bp':  d_utr_med,
        'b_utr_median_bp':  b_utr_med,
        'mannwhitney_p_utr':float(mw_p),
        'partial_rho_7mer': round(rho_7mer, 4),
        'partial_p_7mer':   float(p_7mer),
        'partial_rho_are':  round(rho_are, 4),
        'partial_p_are':    float(p_are),
        'cdf_or_ge2_vs_lt2':round(or_7mer_cdf, 4),
        'cdf_p_ge2_vs_lt2': float(p_7mer_cdf),
    }

    # ── Print verification ──────────────────────────────────────────────
    print(f"\n  ARE enrichment (AREScore >= {threshold}):")
    print(f"    Downregulated: {d_pos}/{len(down)} = {d_pct:.1f}%  [expected: 63.3%]")
    print(f"    Background:    {b_pos}/{len(bg)} = {b_pct:.1f}%  [expected: 23.2%]")
    print(f"    Upregulated:   {u_pos}/{len(up)} = {u_pct:.1f}%")
    print(f"\n  Fisher exact (down vs background):")
    print(f"    OR = {or_db:.4f}  [expected: 5.72]")
    print(f"    95% CI = ({ci_db_lo:.2f}, {ci_db_hi:.2f})  [expected: 3.86-8.46]")
    print(f"    p = {p_db:.2e}  [expected: 9.08e-19]")
    print(f"\n  Fisher exact (up vs background):")
    print(f"    OR = {or_ub:.4f}  [expected: 0.31]")
    print(f"    p = {p_ub:.4f}  [expected: 0.0433]")
    print(f"\n  3' UTR length (downregulated vs background):")
    print(f"    Medians: {d_utr_med:.0f} vs {b_utr_med:.0f} bp  [expected: 2418 vs 1252]")
    print(f"    Mann-Whitney p = {mw_p:.2e}  [expected: 3.4e-9]")
    print(f"\n  Partial Spearman (7-mer count vs log2FC | log10 UTR length):")
    print(f"    rho = {rho_7mer:.4f}  [expected: -0.156]")
    print(f"    p = {p_7mer:.3e}  [expected: 3.42e-54]")
    print(f"\n  Partial Spearman (AREScore vs log2FC | log10 UTR length):")
    print(f"    rho = {rho_are:.4f}  [expected: -0.373]")
    print(f"    p = {p_are:.3e}")
    print(f"\n  CDF Fisher (>= 2 vs < 2 7-mers):")
    print(f"    OR = {or_7mer_cdf:.4f}  [expected: 3.37]")
    print(f"    p = {p_7mer_cdf:.2e}  [expected: 1.93e-8]")

    return stats


def recompute_rbp_stats(are):
    """
    Recompute RBP motif statistics from scratch.
    Verifies the precomputed values in 03_RBP_specificity.csv.
    Returns dataframe with recomputed statistics.
    """
    print("\nRecomputing RBP motif statistics from scratch...")

    down = are[are['group'] == 'down']
    bg   = are[are['group'] == 'background']
    log_utr = np.log10(are['utr_length'])

    # RBP motif columns — these must be precomputed from 3'UTR sequences
    # and added to the are file. The 02_ARE_annotations.csv contains
    # n_7mer_L2 (ZFP36L2 UAUUUAU count). The other RBP motif counts
    # were computed separately by Venu using the same UTR sequences
    # and stored in 03_RBP_specificity.csv.
    # We verify the ZFP36L2 statistics (the primary test) here fully
    # since n_7mer_L2 is in our input file.

    # ZFP36L2 UAUUUAU — Fisher
    d_pos = (down['n_7mer_L2'] > 0).sum(); d_neg = len(down) - d_pos
    b_pos = (bg['n_7mer_L2']   > 0).sum(); b_neg = len(bg)   - b_pos
    or_z, p_z = fisher_exact([[d_pos,d_neg],[b_pos,b_neg]])

    # ZFP36L2 partial rho — recomputed
    rho_z, p_rho_z = partial_spearman(
        are['n_7mer_L2'].values,
        are['Intervention_logFC'].values,
        log_utr.values
    )

    print(f"  ZFP36L2 Fisher OR={or_z:.4f}  [expected: 2.37]")
    print(f"  ZFP36L2 Fisher p={p_z:.2e}  [expected: 9.65e-6]")
    print(f"  ZFP36L2 partial rho={rho_z:.4f}  [expected: -0.156]")
    print(f"  ZFP36L2 partial p={p_rho_z:.3e}  [expected: 3.42e-54]")

    return {
        'ZFP36L2_OR_recomputed': round(or_z, 4),
        'ZFP36L2_p_recomputed':  float(p_z),
        'ZFP36L2_rho_recomputed':round(rho_z, 4),
        'ZFP36L2_p_rho_recomputed': float(p_rho_z),
    }


