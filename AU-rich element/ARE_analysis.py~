def fig_partial_spearman(are, stats, out_dir):
    """
    Figure S2: Partial Spearman scatter (primary pre-specified test).
    """
    print("\nGenerating Figure S2 (partial Spearman scatter)...")

    # Raw regression line
    m, b = np.polyfit(are['n_7mer_L2'], are['Intervention_logFC'], 1)
    xline = np.linspace(0, are['n_7mer_L2'].max(), 200)

    fig, ax = plt.subplots(figsize=(8.5, 6), facecolor='white')
    ax.set_facecolor('white')

    # Background first
    for grp, col, al, sz, zo in [
        ('background', COL_BG,   0.20, 10, 1),
        ('up',         COL_UP,   0.75, 28, 3),
        ('down',       COL_DOWN, 0.80, 28, 4),
    ]:
        sub = are[are['group'] == grp]
        ax.scatter(sub['n_7mer_L2'], sub['Intervention_logFC'],
                   s=sz, color=col, alpha=al, zorder=zo,
                   linewidths=0, rasterized=True)

    ax.plot(xline, m*xline + b, color='#333333', linewidth=1.6,
            linestyle='--', zorder=5)

    ax.axhline(0, color='#AAAAAA', linewidth=0.7, zorder=0)

    # Stat box — bottom right
    stat_str = (
        f"Partial Spearman \u03c1 = {stats['partial_rho_7mer']:.3f}\n"
        f"p = {stats['partial_p_7mer']:.2e}\n"
        "(controlling log\u2081\u2080 3\u2032 UTR length;\n"
        "Mukherjee et al. 2014)"
    )
    ax.text(0.97, 0.05, stat_str, transform=ax.transAxes,
            fontsize=9, ha='right', va='bottom',
            bbox=dict(boxstyle='round,pad=0.4', fc='white',
                      ec='#CCCCCC', alpha=0.95))

    # Legend
    legend_handles = [
        Line2D([0],[0], marker='o', color='w', markerfacecolor=COL_DOWN,
               markersize=8, alpha=0.85, label=f"Downregulated (n=109)"),
        Line2D([0],[0], marker='o', color='w', markerfacecolor=COL_BG,
               markersize=8, alpha=0.5,  label=f"Background (n=9,588)"),
        Line2D([0],[0], marker='o', color='w', markerfacecolor=COL_UP,
               markersize=8, alpha=0.85, label=f"Upregulated (n=35)"),
        Line2D([0],[0], color='#333333', linewidth=1.6, linestyle='--',
               label="Linear trend (raw)"),
    ]
    ax.legend(handles=legend_handles, fontsize=9, loc='upper right',
              frameon=True, framealpha=0.9, edgecolor='#CCCCCC')

    ax.set_xlabel(
        "No. of UAUUUAU heptamers in annotated 3\u2032 UTR\n"
        "(ZFP36 family recognition motif; Redmon et al. 2022)",
        fontsize=10.5)
    ax.set_ylabel(
        "log\u2082FC (ITT interaction term;\nSKY vs control, post \u2212 pre)",
        fontsize=10.5)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)

    plt.tight_layout()
    out = os.path.join(out_dir, "Fig_S2_partial_Spearman.pdf")
    plt.savefig(out, format='pdf', bbox_inches='tight', facecolor='white')
    plt.close()
    print(f"  Saved: {out}")


